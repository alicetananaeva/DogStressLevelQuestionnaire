# DSLQ App - Streamlit Secrets Template
#
# Copy this file to .streamlit/secrets.toml and fill in your real values.
# NEVER commit secrets.toml to the repository - it is in .gitignore.
#
# In Streamlit Community Cloud: add these key-value pairs under
# Settings -> Secrets (TOML format).

# Supabase storage (planned for cloud version)
[supabase]
url = "your_supabase_url"
key = "your_supabase_anon_or_service_key"
table = "dslq_sessions"

# Local only (current default - no secrets needed)
# Sessions are saved to dslq_sessions/ folder on disk.
# Note: on Streamlit Community Cloud, local files are ephemeral (lost on restart).
