# DSLQ App - Streamlit Secrets Template
#
# Copy this file to .streamlit/secrets.toml and fill in your real values.
# NEVER commit secrets.toml to the repository - it is in .gitignore.
#
# In Streamlit Community Cloud: add these under Settings -> Secrets (TOML format).

[supabase]
url = "https://your-project-id.supabase.co"
key = "your-anon-public-key"
